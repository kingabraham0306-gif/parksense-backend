{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
